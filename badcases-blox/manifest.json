{
  "manifest_version": 3,
  "name": "BadCase's BloX",
  "version": "1.1",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "img/icon16.png",
      "32": "img/icon32.png",
      "48": "img/icon48.png",
      "128": "img/icon128.png"
    },
    "default_title": "Blox by BadCase"
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://twitter.com/*"
      ],
      "js": [
        "storage.js",
        "observer.js",
        "panel.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["img/*.svg", "img/*.png", "trophy.html",
      "trophy.css",
      "trophy.js"],
      "matches": ["*://x.com/*", "*://twitter.com/*"]
    }
  ]
}